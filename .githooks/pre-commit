#!/usr/bin/env bash
# .githooks/pre-commit
# Vérifications qualité avant chaque commit

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "=== PRE-COMMIT — eFatura ==="

ERRORS=0

# 1. Vérifier les fichiers Java modifiés
JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$' || true)

if [ -n "$JAVA_FILES" ]; then

    # 2. Détecter System.out.println (interdit — utiliser SLF4J)
    echo "  Vérification System.out.println..."
    SYSOUT=$(echo "$JAVA_FILES" | xargs grep -l "System\.out\.println" 2>/dev/null || true)
    if [ -n "$SYSOUT" ]; then
        echo -e "  ${RED}[ERRO] System.out.println détecté (utiliser log.info/error) :${NC}"
        echo "$SYSOUT" | while read f; do echo "    - $f"; done
        ERRORS=$((ERRORS + 1))
    fi

    # 3. Détecter TODO/FIXME/HACK non résolus
    echo "  Vérification TODO/FIXME..."
    TODOS=$(echo "$JAVA_FILES" | xargs grep -ln "TODO\|FIXME\|HACK" 2>/dev/null || true)
    if [ -n "$TODOS" ]; then
        echo -e "  ${YELLOW}[AVISO] TODO/FIXME présents :${NC}"
        echo "$TODOS" | while read f; do echo "    - $f"; done
    fi

    # 4. Détecter float/double pour montants monétaires
    echo "  Vérification types monétaires..."
    FLOATS=$(echo "$JAVA_FILES" | xargs grep -ln "double\|float" 2>/dev/null | grep -v "test\|Test" || true)
    if [ -n "$FLOATS" ]; then
        echo -e "  ${YELLOW}[AVISO] float/double détecté (utiliser BigDecimal pour montants) :${NC}"
        echo "$FLOATS" | while read f; do echo "    - $f"; done
    fi

    # 5. Détecter credentials en dur
    echo "  Vérification credentials..."
    CREDS=$(echo "$JAVA_FILES" | xargs grep -ln "password\s*=\s*\"[^\"]\|secret\s*=\s*\"[^\"]\|apiKey\s*=\s*\"" 2>/dev/null || true)
    if [ -n "$CREDS" ]; then
        echo -e "  ${RED}[ERRO] Credentials potentiels en dur détectés :${NC}"
        echo "$CREDS" | while read f; do echo "    - $f"; done
        ERRORS=$((ERRORS + 1))
    fi
fi

# 6. Vérifier que .env n'est pas commité
ENV_STAGED=$(git diff --cached --name-only | grep "^\.env$" || true)
if [ -n "$ENV_STAGED" ]; then
    echo -e "  ${RED}[ERRO] Fichier .env en cours de commit ! Ajoutez-le au .gitignore${NC}"
    ERRORS=$((ERRORS + 1))
fi

# 7. Vérifier les gros fichiers (> 5 MB)
echo "  Vérification taille des fichiers..."
BIG_FILES=$(git diff --cached --name-only | while read f; do
    if [ -f "$f" ]; then
        SIZE=$(wc -c < "$f")
        if [ "$SIZE" -gt 5242880 ]; then echo "$f ($((SIZE/1024/1024))MB)"; fi
    fi
done || true)
if [ -n "$BIG_FILES" ]; then
    echo -e "  ${YELLOW}[AVISO] Fichiers volumineux (>5MB) :${NC}"
    echo "$BIG_FILES" | while read f; do echo "    - $f"; done
fi

# Résultat final
echo ""
if [ "$ERRORS" -gt 0 ]; then
    echo -e "  ${RED}COMMIT BLOQUÉ — $ERRORS erreur(s) critique(s) à corriger${NC}"
    echo ""
    exit 1
else
    echo -e "  ${GREEN}Vérifications OK — commit autorisé${NC}"
    echo ""
    exit 0
fi
