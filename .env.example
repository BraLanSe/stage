SERVICE_PROFILE=development
SERVICE_PORT=8080
SERVICE_NAME=efatura-service

KUBERNETES_DISCOVERY_ENABLED=false

LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_SPRING_WEB=DEBUG
LOGGING_LEVEL_APP=DEBUG

HIBERNATE_DDL=update
ENABLE_HIBERNATE_SQL=false
ENABLE_HIBERNATE_FORMAT_SQL=false
DB_SCHEMA=public

POSTGRES_SERVICE_NAME=postgres
# Use <localhost> to conect to a database in docker with api outside, use <host.docker.internal> when running the full app, database inside docker desktop locally
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DATABASE=efatura_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

AUTH_JWT_ISSUER=http://localhost:8090/realms/quickstart
OTEL_ENABLED=true
OTEL_HTTP_PORT=4318
OTEL_COLLECTOR_ENDPOINT="http://host.docker.internal:${OTEL_HTTP_PORT}"
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_SERVICE_NAME="${SERVICE_NAME}"

TEMPO_SERVICE_NAME=tempo
TEMPO_SERVICE_HTTP_PORT=3200
TEMPO_SERVICE_ZIPKIN_PORT=9411

PROMETHEUS_SERVICE_NAME=prometheus
PROMETHEUS_SERVICE_PORT=9090

PROMTAIL_SERVICE_PORT=9080

LOKI_SERVICE_NAME=loki
LOKI_SERVICE_PORT=3100

GRAFANA_SERVICE_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
GRAFANA_ALLOW_SIGN_UP=false

OTEL_COLLECTOR_SERVICE_NAME=otel-collector
OTEL_PPROF_EXTENSION=1888
OTEL_PROMETHEUS_METRICS_EXPORTER_PORT=8888
OTEL_PROMETHEUS_COLLECTOR_METRICS_EXPORTER_PORT=8889
OTEL_HEALTH_CHECK_PORT=13133
OTEL_GRPC_PORT=4317
OTEL_ZPAGES_PORT=55679
ENABLE_SWAGGER=true

EUREKA_CLIENT_ENABLED=false
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://igrp-eureka:8761/eureka/
EUREKA_CLIENT_REGISTERWITHEUREKA=true
EUREKA_CLIENT_FETCHREGISTRY=true

SPRING_CLOUD_DISCOVERY_ENABLED=true
SPRING_CLOUD_GATEWAY_DISCOVERY_LOCATOR_ENABLED=true
SPRING_CLOUD_GATEWAY_DISCOVERY_LOCATOR_LOWER_CASE_SERVICE_ID=true

AUTH_JWT_ISSUER=http://localhost:8090/realms/quickstart
IGRP_ACCESS_API_BASE_URL=